<%= render 'shared/form_error_messages', object: stadium %>

<%= form_with(model: stadium, class: "space-y-4") do |form| %>
  <div>
    <%= form.label :name, "球場名", class: "block font-semibold mb-1" %>
    <%= form.text_field :name, class: "w-full p-2 border rounded-lg" %>
  </div>

  <div class="flex items-center gap-4">
    <%= form.submit "保存する", class: "bg-blue-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
    <%= link_to "キャンセル", stadiums_path, class: "text-gray-600 hover:underline" %>
  </div>
<% end %>
