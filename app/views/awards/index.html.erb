<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">タイトルマスタ</h1>
    <%= link_to '新規年度追加', new_award_path, class: "bg-blue-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-700 transition" %>
  </div>

  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-xl font-semibold mb-4">年度を選択</h2>
    <div class="flex items-center">
      <select id="year-select" class="w-48 p-2 border rounded-lg bg-white">
        <option value="">選択してください</option>
        <% @years.each do |year| %>
          <option value="<%= edit_award_path(year) %>"><%= year %>年</option>
        <% end %>
      </select>
      <button id="show-year-button" class="ml-4 bg-blue-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-700 transition">表示</button>
    </div>
  </div>
</div>

<script>
  document.getElementById('show-year-button').addEventListener('click', function() {
    var select = document.getElementById('year-select');
    var url = select.value;
    if (url) {
      window.location.href = url;
    }
  });
</script>